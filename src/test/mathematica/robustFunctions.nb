Cell[CellGroupData[{

Cell["Huber robust function", "Subsection",
 CellChangeTimes->{{3.964104762519124*^9, 3.9641047668549833`*^9}, {
  3.964114102635249*^9, 
  3.9641141036742496`*^9}},ExpressionUUID->"2bc862ed-30d1-41b7-82de-\
a411fda7365a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rhoHuber", "[", 
   RowBox[{"x_", ",", "k_"}], "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "^", "2"}], "/", "2"}], ",", 
       RowBox[{
        RowBox[{"Abs", "[", "x", "]"}], "\[LessEqual]", "k"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"k", " ", 
         RowBox[{"Abs", "[", "x", "]"}]}], "-", 
        RowBox[{
         RowBox[{"k", "^", "2"}], "/", "2"}]}], ",", 
       RowBox[{
        RowBox[{"Abs", "[", "x", "]"}], ">", "k"}]}], "}"}]}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"rhoHuber", "[", 
    RowBox[{"x", ",", "k"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "2"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9641047798646107`*^9, 3.964104802125573*^9}, {
  3.964104942403101*^9, 3.9641049498550987`*^9}, {3.96411373514497*^9, 
  3.964113758480023*^9}, {3.964113829639077*^9, 3.964113859148381*^9}, {
  3.964148170638153*^9, 3.964148179055792*^9}, {3.964157793303364*^9, 
  3.9641578203105383`*^9}},ExpressionUUID->"c76cf501-421e-450d-8c11-\
20c4fb8d63a4"],

